HOST=0.0.0.0
PORT=8000
UPLOAD_DIR=./uploads/pdfs
FRONTEND_DIR=../frontend

# Python UTF-8 모드 (Windows CP949 인코딩 충돌 방지)
PYTHONUTF8=1
PYTHONIOENCODING=utf-8

# Cloud SQL PostgreSQL 연결 (로컬: docker 또는 cloud-sql-proxy 사용)
DATABASE_URL=postgresql://msds_user:password@localhost/msds

# 관리자 계정
ADMIN_ID=admin
ADMIN_PW=changeme

# JWT 서명 키 (미설정 시 ADMIN_PW에서 파생 — 프로덕션에서는 반드시 별도 설정)
JWT_SECRET=

# CORS 허용 오리진 (쉼표 구분, 미설정 시 cross-origin 차단)
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# 개발 모드 자동 리로드 (프로덕션에서는 false)
DEV_RELOAD=false

# Claude AI 분석 (없으면 수동 입력 모드로 전환)
ANTHROPIC_API_KEY=your_api_key_here
