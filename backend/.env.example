# ===== 서버 설정 (로컬 개발용) =====
HOST=0.0.0.0
PORT=8000
PYTHONUTF8=1
PYTHONIOENCODING=utf-8

# 개발 모드 자동 리로드 (프로덕션에서는 false)
DEV_RELOAD=false

# ===== 관리자 계정 =====
ADMIN_ID=admin
ADMIN_PW=your_secure_password_here

# JWT 서명 키 (미설정 시 ADMIN_PW에서 파생 — 프로덕션에서는 반드시 별도 설정)
JWT_SECRET=

# ===== CORS =====
# 쉼표 구분, 미설정 시 cross-origin 차단, * 설정 시 전체 허용
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# ===== Supabase =====
# Supabase 프로젝트 URL (Settings > API > Project URL)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Supabase Service Role Key (Settings > API > service_role — 절대 외부 노출 금지)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Storage 버킷명 (기본값: pdfs)
STORAGE_BUCKET=pdfs

# Supabase PostgreSQL 연결 문자열
# Transaction Pooler (Vercel 서버리스 권장, port 6543):
#   postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Direct Connection (로컬 개발, port 5432):
#   postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres

# ===== Anthropic Claude AI =====
# 없으면 수동 입력 모드로 전환
ANTHROPIC_API_KEY=sk-ant-...
