{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "250mb" }
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/api/(.*)",       "dest": "/api/index.py" },
    { "src": "/js/(.*)",        "dest": "/frontend/js/$1" },
    { "src": "/css/(.*)",       "dest": "/frontend/css/$1" },
    { "src": "/admin.html",     "dest": "/frontend/admin.html" },
    { "src": "/dashboard.html", "dest": "/frontend/dashboard.html" },
    { "src": "/",               "dest": "/frontend/index.html" }
  ]
}
